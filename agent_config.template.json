{
  "version": 2,
  "agents": {
    "defaults": {
      "workspace": "/root/.picoclaw",
      "model_name": "minimax",
      "restrict_to_workspace": false
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "{{TELEGRAM_TOKEN}}",
      "allow_from": ["{{USER_CHAT_ID}}"],
      "streaming": {
        "enabled": false
      }
    }
  },
  "tools": {
    "exec": {
      "enabled": true,
      "allow_remote": true,
      "enable_deny_patterns": false
    }
  },
  "model_list": [{
    "model_name": "minimax",
    "model": "minimax-with-openrouter-fallback",
    "api_base": "http://62.106.66.13:3000/v1",
    "api_keys": ["{{API_KEY}}"],
    "extra_body": {
      "stream": false
    }
  }]
}
